<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<meta name="theme-color" content="#B8242A">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<title>Factory of Flowers — Mulhouse Flowers Store</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;0,600;0,700;0,800;0,900;1,400;1,500;1,700&family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400;1,500&family=Montserrat:wght@200;300;400;500;600;700&display=swap" rel="stylesheet">
<style>
*{margin:0;padding:0;box-sizing:border-box}
:root{
  --red:#B8242A;--red-light:#D4444A;--red-dark:#8B1A1E;--red-deep:#6B1115;
  --red-glow:rgba(184,36,42,0.12);--red-glow-md:rgba(184,36,42,0.22);--red-glow-strong:rgba(184,36,42,0.35);
  --white:#FEFEFE;--off-white:#FAF7F5;--cream:#F5F0EB;
  --black:#111;--black-soft:#1A1A1A;--gray:#7A7A7A;--gray-light:#B5B0AB;
  --gold:#D4A574;--gold-light:#E8C9A0;
}
html{scroll-behavior:smooth;overflow-x:hidden}
body{font-family:'Cormorant Garamond',serif;background:var(--white);color:var(--black);overflow-x:hidden;-webkit-font-smoothing:antialiased;-webkit-tap-highlight-color:transparent}

/* ========== KEYFRAMES ========== */
@keyframes squishIn{0%{transform:scale(0)rotate(-8deg);opacity:0}55%{transform:scale(1.1)rotate(2deg)}75%{transform:scale(0.94)rotate(-1deg)}90%{transform:scale(1.03)}100%{transform:scale(1)rotate(0);opacity:1}}
@keyframes floatSlow{0%,100%{transform:translateY(0)rotate(0deg)}50%{transform:translateY(-14px)rotate(2deg)}}
@keyframes floatMed{0%,100%{transform:translateY(0)rotate(0deg)}50%{transform:translateY(-10px)rotate(-1.5deg)}}
@keyframes pulseRed{0%,100%{box-shadow:0 0 40px var(--red-glow),0 0 80px transparent}50%{box-shadow:0 0 60px var(--red-glow-md),0 0 120px var(--red-glow)}}
@keyframes heartBeat{0%,100%{transform:scale(1)}14%{transform:scale(1.2)}28%{transform:scale(1)}42%{transform:scale(1.15)}56%{transform:scale(1)}}
@keyframes shimmer{0%{background-position:-200% center}100%{background-position:200% center}}
@keyframes petalSpin{0%{transform:rotate(0deg)}100%{transform:rotate(360deg)}}
@keyframes fadeUp{0%{opacity:0;transform:translateY(50px)}100%{opacity:1;transform:translateY(0)}}
@keyframes scaleReveal{0%{opacity:0;transform:scale(0.85)}100%{opacity:1;transform:scale(1)}}
@keyframes slideInLeft{0%{opacity:0;transform:translateX(-60px)}100%{opacity:1;transform:translateX(0)}}
@keyframes slideInRight{0%{opacity:0;transform:translateX(60px)}100%{opacity:1;transform:translateX(0)}}
@keyframes glowPulse{0%,100%{opacity:0.4}50%{opacity:0.8}}
@keyframes particleFloat{0%{transform:translateY(0) translateX(0) scale(1);opacity:0}10%{opacity:1}90%{opacity:1}100%{transform:translateY(-100vh) translateX(30px) scale(0);opacity:0}}
@keyframes marquee{0%{transform:translateX(0)}100%{transform:translateX(-50%)}}
@keyframes borderGlow{0%,100%{border-color:rgba(184,36,42,0.2)}50%{border-color:rgba(184,36,42,0.5)}}
@keyframes textRevealClip{0%{clip-path:inset(0 100% 0 0)}100%{clip-path:inset(0 0 0 0)}}
@keyframes lipKiss{0%{transform:scale(1)}15%{transform:scale(1.12,0.9)}30%{transform:scale(0.92,1.08)}45%{transform:scale(1.04,0.97)}60%{transform:scale(1)}100%{transform:scale(1)}}
@keyframes counterSpin{0%{transform:rotate(0deg)}100%{transform:rotate(-360deg)}}

/* ========== GLOBAL SQUISHY ========== */
.sq{transition:transform 0.4s cubic-bezier(0.34,1.56,0.64,1)}
.sq:hover{transform:scale(1.05)}
.sq:active{transform:scale(0.94);transition:transform 0.1s ease}

/* ========== SCROLL REVEAL ========== */
.rv{opacity:0;transform:translateY(45px);transition:all 0.9s cubic-bezier(0.22,1,0.36,1)}
.rv.vis{opacity:1;transform:translateY(0)}
.rv-d1{transition-delay:.12s}.rv-d2{transition-delay:.24s}.rv-d3{transition-delay:.36s}.rv-d4{transition-delay:.48s}
.rv-scale{opacity:0;transform:scale(0.85);transition:all 0.8s cubic-bezier(0.22,1,0.36,1)}
.rv-scale.vis{opacity:1;transform:scale(1)}
.rv-left{opacity:0;transform:translateX(-50px);transition:all 0.8s cubic-bezier(0.22,1,0.36,1)}
.rv-left.vis{opacity:1;transform:translateX(0)}
.rv-right{opacity:0;transform:translateX(50px);transition:all 0.8s cubic-bezier(0.22,1,0.36,1)}
.rv-right.vis{opacity:1;transform:translateX(0)}

/* ========== PARTICLE CANVAS ========== */
#particles{position:fixed;top:0;left:0;width:100%;height:100%;pointer-events:none;z-index:0}

/* ========== RED AMBIENT GLOWS ========== */
.ambient-glow{position:fixed;border-radius:50%;pointer-events:none;z-index:0;filter:blur(80px)}
.glow-1{top:-15%;right:-10%;width:500px;height:500px;background:radial-gradient(circle,rgba(184,36,42,0.12),transparent 70%);animation:glowPulse 5s ease-in-out infinite}
.glow-2{bottom:-15%;left:-10%;width:450px;height:450px;background:radial-gradient(circle,rgba(184,36,42,0.08),transparent 70%);animation:glowPulse 5s ease-in-out infinite 2.5s}
.glow-3{top:40%;left:50%;transform:translateX(-50%);width:600px;height:600px;background:radial-gradient(circle,rgba(184,36,42,0.04),transparent 60%);animation:glowPulse 7s ease-in-out infinite 1s}

/* ========== NAV ========== */
nav{position:fixed;top:0;left:0;width:100%;z-index:1000;padding:16px 24px;display:flex;justify-content:space-between;align-items:center;background:rgba(254,254,254,0.75);backdrop-filter:blur(24px);-webkit-backdrop-filter:blur(24px);border-bottom:1px solid rgba(184,36,42,0.05);transition:all .35s ease}
nav.scrolled{padding:10px 24px;background:rgba(254,254,254,0.92);box-shadow:0 4px 40px rgba(184,36,42,0.06)}

.nav-logo{display:flex;align-items:center;gap:10px;text-decoration:none}
.nav-logo-icon{width:34px;height:34px;border-radius:50%;overflow:hidden;border:1.5px solid var(--red);padding:2px;transition:all .3s ease}
.nav-logo-icon img{width:100%;height:100%;object-fit:cover;border-radius:50%}
.nav-logo:hover .nav-logo-icon{transform:scale(1.1);box-shadow:0 0 20px var(--red-glow-md)}
.nav-brand{font-family:'Playfair Display',serif;font-size:1rem;font-weight:700;color:var(--black)}
.nav-brand span{color:var(--red)}

.nav-links{display:flex;gap:28px;list-style:none}
.nav-links a{font-family:'Montserrat',sans-serif;font-size:.68rem;font-weight:500;text-transform:uppercase;letter-spacing:.16em;color:var(--black-soft);text-decoration:none;position:relative;padding-bottom:4px;transition:color .3s}
.nav-links a::after{content:'';position:absolute;bottom:0;left:50%;width:0;height:1.5px;background:var(--red);transition:all .35s cubic-bezier(0.34,1.56,0.64,1);transform:translateX(-50%)}
.nav-links a:hover{color:var(--red)}
.nav-links a:hover::after{width:100%}

.nav-cta{font-family:'Montserrat',sans-serif;font-size:.68rem;font-weight:600;text-transform:uppercase;letter-spacing:.1em;padding:10px 24px;background:var(--red);color:#fff;border:none;border-radius:50px;cursor:pointer;text-decoration:none;transition:all .4s cubic-bezier(0.34,1.56,0.64,1)}
.nav-cta:hover{transform:scale(1.06);background:var(--red-dark);box-shadow:0 8px 30px var(--red-glow-strong)}

.menu-btn{display:none;flex-direction:column;gap:5px;cursor:pointer;padding:6px;z-index:1100}
.menu-btn span{width:22px;height:2px;background:var(--black);transition:all .3s;border-radius:2px}
.menu-btn.on span:nth-child(1){transform:rotate(45deg) translate(5px,5px)}
.menu-btn.on span:nth-child(2){opacity:0}
.menu-btn.on span:nth-child(3){transform:rotate(-45deg) translate(5px,-5px)}

/* ========== HERO ========== */
.hero{min-height:100svh;display:flex;flex-direction:column;justify-content:center;align-items:center;text-align:center;padding:110px 24px 70px;position:relative;overflow:hidden}

/* Red gradient stripe top */
.hero::before{content:'';position:absolute;top:0;left:0;width:100%;height:4px;background:linear-gradient(90deg,transparent,var(--red),transparent)}

/* ---- FLOWER-SHAPED LOGO ---- */
.logo-bloom{position:relative;width:220px;height:220px;margin-bottom:36px;animation:squishIn 1.1s cubic-bezier(0.34,1.56,0.64,1) forwards}

/* Spinning petal ring */
.petal-ring{position:absolute;top:50%;left:50%;width:240px;height:240px;transform:translate(-50%,-50%);animation:petalSpin 30s linear infinite}
.petal{position:absolute;width:50px;height:70px;background:var(--red);border-radius:50% 50% 50% 50% / 60% 60% 40% 40%;opacity:0.12;top:50%;left:50%;transform-origin:0 0}

/* Glow ring */
.logo-glow{position:absolute;top:50%;left:50%;width:200px;height:200px;transform:translate(-50%,-50%);border-radius:50%;background:radial-gradient(circle,var(--red-glow-md) 0%,transparent 70%);animation:pulseRed 3s ease-in-out infinite}

/* Inner petal border (static flower shape via clip-path) */
.logo-flower-border{position:absolute;top:50%;left:50%;width:195px;height:195px;transform:translate(-50%,-50%);border-radius:50%;border:2px solid var(--red);opacity:0.25;animation:borderGlow 3s ease-in-out infinite}

/* Actual logo circle */
.logo-circle{position:absolute;top:50%;left:50%;width:170px;height:170px;transform:translate(-50%,-50%);border-radius:50%;overflow:hidden;border:2.5px solid var(--red);box-shadow:0 0 40px var(--red-glow-md),0 0 80px var(--red-glow),inset 0 0 30px rgba(184,36,42,0.05);background:#fff;z-index:2;transition:all .4s cubic-bezier(0.34,1.56,0.64,1)}
.logo-circle:hover{transform:translate(-50%,-50%) scale(1.06);box-shadow:0 0 60px var(--red-glow-strong),0 0 120px var(--red-glow-md)}
.logo-circle img{width:100%;height:100%;object-fit:cover}

/* Small decorative petals around logo */
.deco-petal{position:absolute;width:14px;height:22px;background:var(--red);border-radius:50% 50% 50% 50%/60% 60% 40% 40%;opacity:0.18;z-index:1}

.hero-tag{font-family:'Montserrat',sans-serif;font-size:.6rem;font-weight:600;text-transform:uppercase;letter-spacing:.3em;color:var(--red);margin-bottom:14px;animation:fadeUp .8s ease .5s both}
.hero-tag::before,.hero-tag::after{content:'—';margin:0 10px;opacity:0.4}

.hero-h1{font-family:'Playfair Display',serif;font-size:clamp(2rem,7vw,4.8rem);font-weight:900;line-height:1.02;color:var(--black);margin-bottom:18px;animation:fadeUp .9s ease .7s both}
.hero-h1 .accent{color:var(--red);font-style:italic}
.hero-h1 .thin{font-weight:400;font-style:italic;color:var(--gray)}

.hero-sub{font-family:'Cormorant Garamond',serif;font-size:clamp(1rem,2.8vw,1.3rem);font-weight:300;color:var(--gray);max-width:420px;line-height:1.7;margin-bottom:36px;animation:fadeUp .9s ease .9s both}

.hero-buttons{display:flex;gap:14px;flex-wrap:wrap;justify-content:center;animation:fadeUp .9s ease 1.1s both}

.btn-glow{display:inline-flex;align-items:center;gap:8px;font-family:'Montserrat',sans-serif;font-size:.75rem;font-weight:600;text-transform:uppercase;letter-spacing:.13em;padding:16px 38px;background:var(--red);color:#fff;border:none;border-radius:50px;cursor:pointer;text-decoration:none;position:relative;overflow:hidden;transition:all .4s cubic-bezier(0.34,1.56,0.64,1)}
.btn-glow::before{content:'';position:absolute;top:0;left:-100%;width:100%;height:100%;background:linear-gradient(90deg,transparent,rgba(255,255,255,.25),transparent);animation:shimmer 2.5s ease-in-out infinite}
.btn-glow:hover{transform:scale(1.07);box-shadow:0 12px 50px var(--red-glow-strong)}
.btn-glow:active{transform:scale(0.95)}
.btn-glow .heart{display:inline-block;animation:heartBeat 1.5s ease-in-out infinite}

.btn-outline{display:inline-flex;align-items:center;gap:8px;font-family:'Montserrat',sans-serif;font-size:.72rem;font-weight:500;text-transform:uppercase;letter-spacing:.12em;padding:14px 32px;background:transparent;color:var(--red);border:1.5px solid var(--red);border-radius:50px;cursor:pointer;text-decoration:none;transition:all .4s cubic-bezier(0.34,1.56,0.64,1)}
.btn-outline:hover{background:var(--red);color:#fff;transform:scale(1.06);box-shadow:0 8px 30px var(--red-glow)}

/* ========== RED DIVIDER ========== */
.red-divider{width:100%;height:80px;background:var(--red);position:relative;overflow:hidden;display:flex;align-items:center}
.red-divider-track{display:flex;animation:marquee 20s linear infinite;white-space:nowrap}
.red-divider-text{font-family:'Playfair Display',serif;font-size:1.1rem;font-weight:700;color:rgba(255,255,255,0.2);text-transform:uppercase;letter-spacing:.2em;padding:0 40px}

/* ========== COLLECTIONS ========== */
.collections{padding:100px 24px;background:var(--white);position:relative;z-index:1}
.collections-head{text-align:center;margin-bottom:60px}

.sticker{display:inline-block;font-family:'Montserrat',sans-serif;font-size:.55rem;font-weight:700;text-transform:uppercase;letter-spacing:.25em;color:var(--red);background:rgba(184,36,42,0.06);padding:6px 18px;border-radius:50px;border:1px solid rgba(184,36,42,0.12);margin-bottom:14px}

.s-title{font-family:'Playfair Display',serif;font-size:clamp(1.8rem,5vw,3.2rem);font-weight:900;color:var(--black);line-height:1.08;margin-bottom:14px}
.s-title i{color:var(--red);font-style:italic}

.s-desc{font-family:'Cormorant Garamond',serif;font-size:1.15rem;font-weight:300;color:var(--gray);line-height:1.7;max-width:480px;margin:0 auto}

.col-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:20px;max-width:1100px;margin:0 auto}

.col-card{position:relative;border-radius:22px;overflow:hidden;aspect-ratio:3/4;cursor:pointer;transition:all .55s cubic-bezier(0.22,1,0.36,1)}
.col-card::before{content:'';position:absolute;inset:0;border:1.5px solid rgba(184,36,42,0);border-radius:22px;z-index:3;transition:border-color .4s}
.col-card:hover::before{border-color:rgba(184,36,42,0.4)}
.col-card:hover{transform:scale(1.03) translateY(-6px);box-shadow:0 24px 70px rgba(184,36,42,0.18)}
.col-card:active{transform:scale(0.97)}

.col-card img{width:100%;height:100%;object-fit:cover;transition:transform .7s cubic-bezier(0.22,1,0.36,1)}
.col-card:hover img{transform:scale(1.1)}

.col-overlay{position:absolute;bottom:0;left:0;right:0;padding:28px 20px 22px;background:linear-gradient(transparent,rgba(0,0,0,0.75));z-index:2}
.col-tag{font-family:'Montserrat',sans-serif;font-size:.55rem;font-weight:600;text-transform:uppercase;letter-spacing:.2em;color:var(--red-light);margin-bottom:4px}
.col-name{font-family:'Playfair Display',serif;font-size:1.3rem;font-weight:700;color:#fff}
.col-sub{font-family:'Cormorant Garamond',serif;font-size:.9rem;color:rgba(255,255,255,0.7);margin-top:2px}

/* ========== ABOUT SECTION - SPLIT ========== */
.about{padding:100px 24px;background:var(--off-white);position:relative;overflow:hidden}
.about::before{content:'';position:absolute;top:0;left:0;width:100%;height:1px;background:linear-gradient(90deg,transparent,rgba(184,36,42,0.15),transparent)}

.about-grid{display:grid;grid-template-columns:1fr 1fr;gap:60px;max-width:1000px;margin:0 auto;align-items:center}

.about-img-wrap{position:relative}
.about-img{width:100%;border-radius:24px;aspect-ratio:3/4;object-fit:cover;box-shadow:0 20px 60px rgba(0,0,0,0.1)}
.about-img-accent{position:absolute;top:-15px;right:-15px;width:100%;height:100%;border-radius:24px;border:2px solid var(--red);opacity:0.15;z-index:-1}

.about-content .sticker{margin-bottom:14px}
.about-content .s-title{text-align:left;margin-bottom:18px}
.about-text{font-family:'Cormorant Garamond',serif;font-size:1.15rem;font-weight:300;color:var(--gray);line-height:1.8;margin-bottom:14px}
.about-text em{color:var(--red);font-style:italic;font-weight:400}
.about-sig{font-family:'Playfair Display',serif;font-size:1.6rem;font-style:italic;color:var(--red);margin-top:20px;opacity:0.7}

/* ========== STATS BAR ========== */
.stats-bar{padding:50px 24px;background:var(--red);position:relative;overflow:hidden}
.stats-bar::before{content:'';position:absolute;inset:0;background:url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='0.03'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E")}

.stats-grid{display:flex;justify-content:center;gap:60px;flex-wrap:wrap;max-width:800px;margin:0 auto}
.stat-item{text-align:center}
.stat-num{font-family:'Playfair Display',serif;font-size:clamp(2rem,5vw,3rem);font-weight:900;color:#fff}
.stat-label{font-family:'Montserrat',sans-serif;font-size:.6rem;font-weight:500;text-transform:uppercase;letter-spacing:.2em;color:rgba(255,255,255,0.6);margin-top:4px}

/* ========== SERVICES ========== */
.services{padding:100px 24px;background:var(--white);position:relative;z-index:1}
.services-head{text-align:center;margin-bottom:60px}

.srv-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:20px;max-width:960px;margin:0 auto}

.srv-card{background:var(--white);border:1px solid rgba(184,36,42,0.08);border-radius:24px;padding:40px 28px 36px;text-align:center;position:relative;overflow:hidden;transition:all .45s cubic-bezier(0.22,1,0.36,1)}
.srv-card::before{content:'';position:absolute;top:0;left:0;width:100%;height:3px;background:var(--red);transform:scaleX(0);transition:transform .4s ease;transform-origin:left}
.srv-card:hover::before{transform:scaleX(1)}
.srv-card:hover{transform:translateY(-6px);border-color:rgba(184,36,42,0.2);box-shadow:0 16px 50px rgba(184,36,42,0.1)}

.srv-icon{width:56px;height:56px;border-radius:50%;background:rgba(184,36,42,0.06);display:flex;align-items:center;justify-content:center;margin:0 auto 18px;font-size:1.5rem;transition:all .4s cubic-bezier(0.34,1.56,0.64,1)}
.srv-card:hover .srv-icon{background:var(--red);transform:scale(1.1) rotate(-5deg)}
.srv-card:hover .srv-icon span{filter:brightness(100)}
.srv-title{font-family:'Playfair Display',serif;font-size:1.1rem;font-weight:700;color:var(--black);margin-bottom:8px}
.srv-desc{font-family:'Cormorant Garamond',serif;font-size:1rem;color:var(--gray);line-height:1.6}

/* ========== GALLERY FULL ========== */
.gallery{padding:80px 0;background:var(--off-white);overflow:hidden;position:relative}
.gallery-head{text-align:center;margin-bottom:44px;padding:0 24px}

.gal-track{display:flex;gap:16px;animation:marquee 30s linear infinite;width:max-content}
.gal-item{width:280px;height:370px;border-radius:18px;overflow:hidden;flex-shrink:0;position:relative;transition:transform .4s cubic-bezier(0.34,1.56,0.64,1)}
.gal-item:hover{transform:scale(1.04) rotate(-1deg)}
.gal-item img{width:100%;height:100%;object-fit:cover;transition:transform .5s ease}
.gal-item:hover img{transform:scale(1.08)}
.gal-item::after{content:'';position:absolute;inset:0;border:1.5px solid rgba(255,255,255,0.1);border-radius:18px;pointer-events:none}

/* ========== TESTIMONIAL / QUOTE ========== */
.quote-section{padding:80px 24px;background:var(--white);text-align:center;position:relative}
.quote-section::before{content:'';position:absolute;top:0;left:50%;transform:translateX(-50%);width:60%;height:1px;background:linear-gradient(90deg,transparent,rgba(184,36,42,0.15),transparent)}
.quote-icon{font-size:3rem;color:var(--red);opacity:0.2;margin-bottom:16px;font-family:'Playfair Display',serif}
.quote-text{font-family:'Playfair Display',serif;font-size:clamp(1.2rem,3vw,1.8rem);font-weight:400;font-style:italic;color:var(--black-soft);max-width:600px;margin:0 auto 16px;line-height:1.5}
.quote-text em{color:var(--red)}
.quote-author{font-family:'Montserrat',sans-serif;font-size:.65rem;font-weight:500;text-transform:uppercase;letter-spacing:.2em;color:var(--gray)}

/* ========== CTA / CONTACT ========== */
.contact{padding:100px 24px;background:linear-gradient(135deg,var(--red-dark) 0%,var(--red) 50%,var(--red-light) 100%);text-align:center;position:relative;overflow:hidden}
.contact::before{content:'';position:absolute;inset:0;background:url("data:image/svg+xml,%3Csvg width='40' height='40' viewBox='0 0 40 40' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='%23ffffff' fill-opacity='0.03' fill-rule='evenodd'%3E%3Cpath d='M20 0C8.954 0 0 8.954 0 20s8.954 20 20 20 20-8.954 20-20S31.046 0 20 0zm0 36c-8.837 0-16-7.163-16-16S11.163 4 20 4s16 7.163 16 16-7.163 16-16 16z'/%3E%3C/g%3E%3C/svg%3E")}

.contact-inner{max-width:520px;margin:0 auto;position:relative;z-index:2}
