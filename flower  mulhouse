<script>
// ===== MENU =====
function toggleMenu(){document.getElementById('navLinks').classList.toggle('open');document.getElementById('menuBtn').classList.toggle('on')}
function closeMenu(){document.getElementById('navLinks').classList.remove('open');document.getElementById('menuBtn').classList.remove('on')}

// ===== NAV SCROLL =====
let lastY=0;
window.addEventListener('scroll',()=>{
  document.getElementById('navbar').classList.toggle('scrolled',window.scrollY>60);
  lastY=window.scrollY;
});

// ===== SCROLL REVEAL =====
const io=new IntersectionObserver(entries=>{
  entries.forEach(e=>{if(e.isIntersecting)e.target.classList.add('vis')})
},{threshold:0.1,rootMargin:'0px 0px -30px 0px'});
document.querySelectorAll('.rv,.rv-scale,.rv-left,.rv-right').forEach(el=>io.observe(el));

// ===== PETAL RING =====
(function(){
  const ring=document.getElementById('petalRing');
  const n=8;
  for(let i=0;i<n;i++){
    const p=document.createElement('div');
    p.className='petal';
    const angle=(360/n)*i;
    const rad=angle*Math.PI/180;
    const r=95;
    const x=Math.cos(rad)*r;
    const y=Math.sin(rad)*r;
    p.style.transform=`translate(${x-25}px,${y-35}px) rotate(${angle+90}deg)`;
    ring.appendChild(p);
  }
})();

// ===== PARTICLES =====
(function(){
  const c=document.getElementById('particles');
  const ctx=c.getContext('2d');
  let w,h,particles=[];
  function resize(){w=c.width=window.innerWidth;h=c.height=window.innerHeight}
  resize();
  window.addEventListener('resize',resize);

  class Particle{
    constructor(){this.reset()}
    reset(){
      this.x=Math.random()*w;
      this.y=h+Math.random()*100;
      this.vx=(Math.random()-0.5)*0.3;
      this.vy=-(0.3+Math.random()*0.5);
      this.size=1+Math.random()*2.5;
      this.alpha=0.08+Math.random()*0.12;
      this.life=0;
      this.maxLife=300+Math.random()*400;
    }
    update(){
      this.x+=this.vx;
      this.y+=this.vy;
      this.life++;
      if(this.life>this.maxLife||this.y<-20)this.reset();
    }
    draw(){
      const progress=this.life/this.maxLife;
      const fade=progress<0.1?progress*10:progress>0.8?(1-progress)*5:1;
      ctx.beginPath();
      ctx.arc(this.x,this.y,this.size,0,Math.PI*2);
      ctx.fillStyle=`rgba(184,36,42,${this.alpha*fade})`;
      ctx.fill();
    }
  }

  for(let i=0;i<40;i++)particles.push(new Particle());
  function animate(){
    ctx.clearRect(0,0,w,h);
    particles.forEach(p=>{p.update();p.draw()});
    requestAnimationFrame(animate);
  }
  animate();
})();

// ===== COUNTER ANIMATION =====
const counterIO=new IntersectionObserver(entries=>{
  entries.forEach(e=>{
    if(e.isIntersecting){
      const el=e.target;
      const target=parseInt(el.dataset.count);
      let current=0;
      const step=Math.ceil(target/60);
      const timer=setInterval(()=>{
        current+=step;
        if(current>=target){current=target;clearInterval(timer)}
        el.textContent=current+'+';
      },25);
      counterIO.unobserve(el);
    }
  });
},{threshold:0.5});
document.querySelectorAll('[data-count]').forEach(el=>counterIO.observe(el));

// ===== SQUISHY LOGO TOUCH =====
const bloom=document.getElementById('logobloom');
bloom.addEventListener('click',()=>{
  bloom.style.animation='lipKiss 0.7s cubic-bezier(0.34,1.56,0.64,1)';
  setTimeout(()=>bloom.style.animation='',700);
});
bloom.addEventListener('touchstart',e=>{
  bloom.style.animation='lipKiss 0.6s cubic-bezier(0.34,1.56,0.64,1)';
  setTimeout(()=>bloom.style.animation='',600);
},{passive:true});

// ===== SMOOTH SCROLL FIX FOR IOS =====
document.querySelectorAll('a[href^="#"]').forEach(a=>{
  a.addEventListener('click',e=>{
    const target=document.querySelector(a.getAttribute('href'));
    if(target){
      e.preventDefault();
      target.scrollIntoView({behavior:'smooth',block:'start'});
    }
  });
});
</script>
