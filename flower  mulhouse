<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Comptoir des Étuves — Montpellier</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;0,900;1,400;1,700&family=DM+Sans:wght@300;400;500&family=Cormorant+Garamond:ital,wght@0,300;0,600;1,300;1,600&display=swap" rel="stylesheet">
<style>
:root {
  --rouge: #C41E1E;
  --rouge-sombre: #8B1010;
  --creme: #F7F2E8;
  --creme-fonce: #EDE5D4;
  --noir: #0C0A08;
  --brun: #1A1208;
  --or: #C8A96E;
  --texte: #2A1F10;
}

* { margin: 0; padding: 0; box-sizing: border-box; }
html { scroll-behavior: smooth; }

body {
  background: var(--creme);
  color: var(--texte);
  font-family: 'DM Sans', sans-serif;
  overflow-x: hidden;
}






/* ─── NAV ─────────────────────────────────── */
nav {
  position: fixed; top: 0; left: 0; right: 0; z-index: 500;
  padding: 0 56px;
  height: 72px;
  display: flex; align-items: center; justify-content: space-between;
  transition: background .4s ease, border-color .4s ease;
}
nav.scrolled {
  background: rgba(247,242,232,0.96);
  backdrop-filter: blur(12px);
  border-bottom: 1px solid rgba(200,169,110,0.3);
}
.nav-brand {
  display: flex; align-items: center; gap: 14px;
}
.nav-logo-img {
  width: 40px; height: 40px;
  border-radius: 50%;
  object-fit: cover;
  border: 1.5px solid rgba(196,30,30,0.3);
}
.nav-brand-text {
  font-family: 'Cormorant Garamond', serif;
  font-size: 1.05rem;
  font-weight: 600;
  letter-spacing: 2px;
  text-transform: uppercase;
  color: var(--texte);
}
.nav-links {
  display: flex; gap: 40px; list-style: none;
}
.nav-links a {
  font-size: .78rem;
  font-weight: 500;
  letter-spacing: 2px;
  text-transform: uppercase;
  color: var(--texte);
  text-decoration: none;
  opacity: .6;
  transition: opacity .2s;
}
.nav-links a:hover { opacity: 1; }
.nav-cta {
  background: var(--rouge);
  color: #fff !important;
  opacity: 1 !important;
  padding: 9px 22px;
  border-radius: 2px;
  font-size: .75rem !important;
  letter-spacing: 2px;
}
.nav-cta:hover { background: var(--rouge-sombre); }

/* ─── HERO ────────────────────────────────── */
.hero {
  min-height: 100vh;
  background: var(--noir);
  display: grid;
  grid-template-columns: 1fr 1fr;
  overflow: hidden;
  position: relative;
}

/* left column */
.hero-left {
  display: flex; flex-direction: column;
  justify-content: center;
  padding: 140px 70px 80px 80px;
  position: relative; z-index: 2;
}
.hero-eyebrow {
  display: flex; align-items: center; gap: 16px;
  margin-bottom: 36px;
}
.hero-eyebrow-line {
  width: 40px; height: 1px;
  background: var(--or);
}
.hero-eyebrow-text {
  font-size: .7rem;
  font-weight: 500;
  letter-spacing: 4px;
  text-transform: uppercase;
  color: var(--or);
}
.hero-h1 {
  font-family: 'Playfair Display', serif;
  font-size: clamp(3.5rem, 6vw, 6rem);
  font-weight: 900;
  line-height: .95;
  color: var(--creme);
  margin-bottom: 8px;
}
.hero-h1 em {
  font-style: italic;
  color: var(--rouge);
  display: block;
}
.hero-h1 span {
  display: block;
  font-size: clamp(1.8rem, 3vw, 3rem);
  font-weight: 400;
  color: rgba(247,242,232,0.45);
  letter-spacing: 3px;
  font-family: 'Cormorant Garamond', serif;
  font-style: normal;
  margin-top: 10px;
}
.hero-desc {
  margin-top: 36px;
  font-size: .9rem;
  line-height: 1.8;
  color: rgba(247,242,232,0.45);
  max-width: 340px;
}
.hero-actions {
  margin-top: 48px;
  display: flex; gap: 20px; align-items: center;
}
.btn-rouge {
  background: var(--rouge);
  color: #fff;
  font-size: .75rem;
  font-weight: 500;
  letter-spacing: 2.5px;
  text-transform: uppercase;
  padding: 16px 36px;
  text-decoration: none;
  border-radius: 2px;
  transition: background .2s, transform .2s;
  display: inline-block;
}
.btn-rouge:hover { background: var(--rouge-sombre); transform: translateY(-2px); }
.btn-ghost {
  font-size: .75rem;
  font-weight: 500;
  letter-spacing: 2px;
  text-transform: uppercase;
  color: rgba(247,242,232,0.5);
  text-decoration: none;
  display: flex; align-items: center; gap: 10px;
  transition: color .2s;
}
.btn-ghost:hover { color: var(--creme); }
.btn-ghost-arrow {
  width: 28px; height: 1px;
  background: currentColor;
  position: relative;
  transition: width .2s;
}
.btn-ghost:hover .btn-ghost-arrow { width: 40px; }
.btn-ghost-arrow::after {
  content: '';
  position: absolute; right: 0; top: -3px;
  border: 4px solid transparent;
  border-left: 6px solid currentColor;
  border-right: none;
}

.hero-stats {
  margin-top: 72px;
  display: flex; gap: 48px;
  border-top: 1px solid rgba(247,242,232,0.08);
  padding-top: 36px;
}
.hero-stat-num {
  font-family: 'Playfair Display', serif;
  font-size: 2.2rem;
  font-weight: 700;
  color: var(--or);
  line-height: 1;
}
.hero-stat-label {
  font-size: .7rem;
  letter-spacing: 2px;
  text-transform: uppercase;
  color: rgba(247,242,232,0.35);
  margin-top: 6px;
}

/* right column */
.hero-right {
  position: relative;
  overflow: hidden;
}
.hero-right-inner {
  position: absolute; inset: 0;
  display: flex; align-items: center; justify-content: center;
}
/* big decorative circle */
.hero-circle {
  width: min(520px, 80%);
  height: min(520px, 80%);
  border-radius: 50%;
  background: radial-gradient(circle at 40% 35%, rgba(196,30,30,0.25) 0%, rgba(139,16,16,0.15) 50%, transparent 70%);
  border: 1px solid rgba(196,30,30,0.15);
  display: flex; align-items: center; justify-content: center;
  animation: slow-spin 30s linear infinite;
}
@keyframes slow-spin {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}
.hero-circle-inner {
  width: 80%; height: 80%;
  border-radius: 50%;
  border: 1px solid rgba(200,169,110,0.1);
  display: flex; align-items: center; justify-content: center;
  animation: slow-spin 30s linear infinite reverse;
}
.hero-logo-big {
  width: min(260px, 55%);
  border-radius: 50%;
  object-fit: cover;
  border: 3px solid rgba(196,30,30,0.3);
  box-shadow:
    0 0 0 12px rgba(196,30,30,0.06),
    0 0 0 24px rgba(196,30,30,0.03),
    0 40px 120px rgba(0,0,0,0.8);
  animation: slow-spin 30s linear infinite; /* counter the parent spin */
  position: relative; z-index: 2;
}
/* decorative dots on circle */
.hero-circle::before {
  content: '';
  position: absolute;
  width: 8px; height: 8px;
  border-radius: 50%;
  background: var(--rouge);
  top: 6%;
  left: 50%;
  box-shadow: 0 0 12px rgba(196,30,30,0.8);
}

/* bg texture on right */
.hero-right::before {
  content: '';
  position: absolute; inset: 0;
  background:
    radial-gradient(ellipse 70% 60% at 50% 50%, rgba(26,18,8,0.5) 0%, transparent 70%),
    linear-gradient(135deg, #0C0A08 0%, #1A1208 100%);
}
/* vertical text right */
.hero-vertical-text {
  position: absolute;
  right: 24px; top: 50%;
  transform: translateY(-50%) rotate(90deg);
  transform-origin: center center;
  font-size: .6rem;
  letter-spacing: 5px;
  text-transform: uppercase;
  color: rgba(200,169,110,0.25);
  white-space: nowrap;
}

/* ─── MARQUEE ─────────────────────────────── */
.marquee-wrap {
  background: var(--rouge);
  overflow: hidden;
  padding: 14px 0;
}
.marquee-track {
  display: flex; gap: 0;
  animation: marquee 20s linear infinite;
  width: max-content;
}
.marquee-item {
  font-family: 'Cormorant Garamond', serif;
  font-size: 1rem;
  font-style: italic;
  font-weight: 300;
  letter-spacing: 3px;
  color: rgba(255,255,255,0.9);
  white-space: nowrap;
  padding: 0 48px;
}
.marquee-item::before {
  content: '✦';
  margin-right: 48px;
  font-style: normal;
  opacity: .6;
}
@keyframes marquee {
  from { transform: translateX(0); }
  to { transform: translateX(-50%); }
}

/* ─── FORMULES ────────────────────────────── */
.section-formules {
  padding: 130px 80px;
  background: var(--creme);
}
.section-header {
  display: flex; align-items: flex-end; justify-content: space-between;
  margin-bottom: 70px;
}
.section-label-wrap { }
.section-label {
  font-size: .65rem;
  font-weight: 500;
  letter-spacing: 4px;
  text-transform: uppercase;
  color: var(--rouge);
  margin-bottom: 14px;
  display: flex; align-items: center; gap: 14px;
}
.section-label::before {
  content: '';
  display: inline-block;
  width: 24px; height: 1px;
  background: var(--rouge);
}
.section-titre {
  font-family: 'Playfair Display', serif;
  font-size: clamp(2.8rem, 5vw, 5rem);
  font-weight: 900;
  line-height: 1;
  color: var(--texte);
}
.section-titre em {
  font-style: italic;
  color: var(--rouge);
}
.section-desc {
  max-width: 280px;
  font-size: .85rem;
  line-height: 1.8;
  color: rgba(42,31,16,0.5);
  text-align: right;
}

.formules-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 2px;
}
.formule-card {
  background: var(--creme-fonce);
  padding: 44px 38px;
  position: relative;
  overflow: hidden;
  transition: background .3s;
  border: 1px solid transparent;
}
.formule-card::after {
  content: '';
  position: absolute;
  bottom: 0; left: 0;
  width: 0; height: 2px;
  background: var(--rouge);
  transition: width .4s ease;
}
.formule-card:hover { background: #fff; border-color: rgba(200,169,110,0.2); }
.formule-card:hover::after { width: 100%; }
.formule-num {
  font-family: 'Playfair Display', serif;
  font-size: .75rem;
  font-style: italic;
  color: rgba(42,31,16,0.25);
  margin-bottom: 28px;
}
.formule-name {
  font-family: 'Playfair Display', serif;
  font-size: 1.5rem;
  font-weight: 700;
  color: var(--texte);
  margin-bottom: 14px;
  line-height: 1.2;
}
.formule-desc {
  font-size: .8rem;
  line-height: 1.7;
  color: rgba(42,31,16,0.5);
  margin-bottom: 32px;
}
.formule-price {
  font-family: 'Cormorant Garamond', serif;
  font-size: 2.2rem;
  font-weight: 600;
  color: var(--rouge);
}
.formule-icon {
  position: absolute;
  top: 36px; right: 36px;
  font-size: 1.6rem;
  opacity: .2;
}

/* ─── MENU ────────────────────────────────── */
.section-menu {
  background: var(--noir);
  padding: 130px 80px;
}
.section-menu .section-titre { color: var(--creme); }
.section-menu .section-desc { color: rgba(247,242,232,0.35); }
.section-menu .section-label { color: var(--or); }
.section-menu .section-label::before { background: var(--or); }

.menu-tabs {
  display: flex; gap: 0;
  margin: 50px 0 50px;
  border-bottom: 1px solid rgba(247,242,232,0.08);
}
.menu-tab {
  font-size: .72rem;
  font-weight: 500;
  letter-spacing: 2px;
  text-transform: uppercase;
  color: rgba(247,242,232,0.35);
  background: none; border: none;
  padding: 14px 28px;
  border-bottom: 2px solid transparent;
  margin-bottom: -1px;
  transition: color .2s;
}
.menu-tab.active, .menu-tab:hover {
  color: var(--creme);
  border-bottom-color: var(--rouge);
}

.menu-panel { display: none; }
.menu-panel.active { display: block; }

.menu-price-banner {
  display: inline-flex; gap: 32px;
  background: rgba(247,242,232,0.04);
  border: 1px solid rgba(200,169,110,0.15);
  padding: 14px 28px;
  border-radius: 2px;
  margin-bottom: 40px;
  flex-wrap: wrap;
}
.menu-price-banner span {
  font-size: .75rem;
  letter-spacing: 1.5px;
  text-transform: uppercase;
  color: var(--or);
}
.menu-price-banner strong {
  color: var(--creme);
  margin-left: 6px;
}

.menu-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
  gap: 1px;
  background: rgba(247,242,232,0.05);
}
.menu-item {
  background: #0C0A08;
  padding: 28px 32px;
  transition: background .2s;
  position: relative;
}
.menu-item:hover { background: #14100A; }
.menu-item-top {
  display: flex; justify-content: space-between; align-items: baseline; gap: 16px;
}
.menu-item-name {
  font-family: 'Cormorant Garamond', serif;
  font-size: 1.15rem;
  font-weight: 600;
  color: var(--creme);
  letter-spacing: .5px;
}
.menu-item-price {
  font-family: 'Playfair Display', serif;
  font-size: 1.1rem;
  font-style: italic;
  color: var(--rouge);
  white-space: nowrap;
  flex-shrink: 0;
}
.menu-item-desc {
  font-size: .72rem;
  line-height: 1.6;
  color: rgba(247,242,232,0.28);
  margin-top: 8px;
  letter-spacing: .5px;
  text-transform: uppercase;
}
.menu-cat-title {
  font-family: 'Playfair Display', serif;
  font-size: 1.6rem;
  font-weight: 700;
  font-style: italic;
  color: var(--or);
  margin: 52px 0 20px;
  padding-bottom: 14px;
  border-bottom: 1px solid rgba(200,169,110,0.15);
}

/* ─── BOISSONS TAB ────────────────────────── */
.boissons-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
  gap: 40px;
}
.boissons-cat h4 {
  font-family: 'Cormorant Garamond', serif;
  font-size: 1.3rem;
  font-weight: 600;
  color: var(--or);
  margin-bottom: 20px;
  padding-bottom: 10px;
  border-bottom: 1px solid rgba(200,169,110,0.15);
}
.boissons-list { list-style: none; }
.boissons-list li {
  display: flex; justify-content: space-between;
  padding: 9px 0;
  border-bottom: 1px solid rgba(247,242,232,0.04);
  font-size: .82rem;
  color: rgba(247,242,232,0.55);
}
.boissons-list li span { color: var(--creme); font-family: 'Cormorant Garamond', serif; font-size: .95rem; }

/* ─── INFOS ────────────────────────────────── */
.section-infos {
  padding: 130px 80px;
  background: var(--creme-fonce);
  display: grid;
  grid-template-columns: 1.2fr 1fr;
  gap: 100px;
  align-items: start;
}
.infos-left .section-label { margin-bottom: 14px; }
.horaires {
  margin-top: 48px;
  border-top: 1px solid rgba(42,31,16,0.1);
}
.horaire-row {
  display: flex; justify-content: space-between;
  padding: 16px 0;
  border-bottom: 1px solid rgba(42,31,16,0.07);
  font-size: .85rem;
}
.horaire-row .jour {
  font-weight: 500;
  letter-spacing: .5px;
  color: rgba(42,31,16,0.6);
  text-transform: uppercase;
  font-size: .75rem;
  letter-spacing: 1.5px;
}
.horaire-row .heure { font-family: 'Cormorant Garamond', serif; font-size: 1rem; font-weight: 600; }
.horaire-row .ferme { color: rgba(196,30,30,0.6); font-style: italic; font-family: 'Cormorant Garamond', serif; font-size: 1rem; }
.horaire-note {
  font-size: .72rem;
  color: rgba(42,31,16,0.35);
  margin-top: 16px;
  letter-spacing: 1px;
}

.infos-right { padding-top: 16px; }
.infos-right .section-titre { font-size: clamp(2rem, 3.5vw, 3.5rem); }
.contact-block { margin-top: 48px; }
.contact-row {
  display: flex; gap: 20px; align-items: flex-start;
  padding: 20px 0;
  border-bottom: 1px solid rgba(42,31,16,0.07);
}
.contact-icon {
  width: 38px; height: 38px;
  border: 1px solid rgba(42,31,16,0.12);
  border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  font-size: .9rem;
  flex-shrink: 0;
  color: var(--rouge);
}
.contact-info .label {
  font-size: .65rem;
  letter-spacing: 2.5px;
  text-transform: uppercase;
  color: rgba(42,31,16,0.4);
  margin-bottom: 5px;
}
.contact-info .val {
  font-family: 'Cormorant Garamond', serif;
  font-size: 1.1rem;
  font-weight: 600;
  color: var(--texte);
}
.contact-info a { color: inherit; text-decoration: none; }

.rating-badge {
  display: inline-flex; align-items: center; gap: 12px;
  background: var(--rouge);
  color: #fff;
  padding: 16px 28px;
  border-radius: 2px;
  margin-top: 36px;
}
.rating-badge .num {
  font-family: 'Playfair Display', serif;
  font-size: 2rem;
  font-weight: 900;
  line-height: 1;
}
.rating-badge .sub {
  font-size: .7rem;
  letter-spacing: 2px;
  text-transform: uppercase;
  opacity: .8;
}
.stars { letter-spacing: 2px; font-size: .8rem; }

/* ─── FOOTER ──────────────────────────────── */
footer {
  background: var(--noir);
  padding: 70px 80px 40px;
  display: grid;
  grid-template-columns: 1fr 1fr 1fr;
  gap: 60px;
}
.footer-logo-area { }
.footer-logo-img {
  width: 52px; height: 52px;
  border-radius: 50%;
  object-fit: cover;
  border: 1px solid rgba(200,169,110,0.25);
  margin-bottom: 16px;
  display: block;
}
.footer-brand {
  font-family: 'Cormorant Garamond', serif;
  font-size: 1.2rem;
  font-weight: 600;
  letter-spacing: 3px;
  text-transform: uppercase;
  color: var(--creme);
  margin-bottom: 8px;
}
.footer-sub {
  font-size: .72rem;
  letter-spacing: 2px;
  color: rgba(247,242,232,0.25);
  text-transform: uppercase;
}
.footer-col-title {
  font-size: .65rem;
  letter-spacing: 3px;
  text-transform: uppercase;
  color: var(--or);
  margin-bottom: 20px;
}
.footer-links { list-style: none; }
.footer-links li { margin-bottom: 10px; }
.footer-links a {
  font-size: .82rem;
  color: rgba(247,242,232,0.4);
  text-decoration: none;
  transition: color .2s;
}
.footer-links a:hover { color: var(--creme); }
.footer-bottom {
  grid-column: 1/-1;
  padding-top: 36px;
  border-top: 1px solid rgba(247,242,232,0.06);
  display: flex; justify-content: space-between; align-items: center;
}
.footer-bottom p {
  font-size: .7rem;
  color: rgba(247,242,232,0.2);
  letter-spacing: 1px;
}
.vegan-badge {
  font-size: .68rem;
  letter-spacing: 2px;
  text-transform: uppercase;
  color: rgba(247,242,232,0.2);
  border: 1px solid rgba(247,242,232,0.1);
  padding: 5px 14px;
  border-radius: 20px;
}

/* HERO LOGO LEFT */
.hero-logo-left-wrap {
  display: flex; align-items: center; gap: 28px;
  margin-top: 52px;
  padding-top: 36px;
  border-top: 1px solid rgba(247,242,232,0.08);
}
.hero-logo-left-img {
  width: 88px; height: 88px;
  border-radius: 50%;
  object-fit: cover;
  border: 2px solid rgba(196,30,30,0.4);
  box-shadow: 0 0 0 8px rgba(196,30,30,0.07), 0 20px 60px rgba(0,0,0,0.6);
  flex-shrink: 0;
}
.hero-logo-left-text .name {
  font-family: 'Cormorant Garamond', serif;
  font-size: 1rem;
  font-weight: 600;
  letter-spacing: 3px;
  text-transform: uppercase;
  color: var(--creme);
  margin-bottom: 4px;
}
.hero-logo-left-text .addr {
  font-size: .72rem;
  letter-spacing: 1.5px;
  text-transform: uppercase;
  color: rgba(247,242,232,0.3);
}

/* ─── REVEAL ──────────────────────────────── */
.reveal {
  opacity: 0;
  transform: translateY(28px);
  transition: opacity .7s ease, transform .7s cubic-bezier(.22,1,.36,1);
}
.reveal.visible { opacity: 1; transform: translateY(0); }

/* ─── MOBILE ──────────────────────────────── */
@media (max-width: 768px) {
  nav { padding: 0 24px; }
  .nav-links { display: none; }
  .hero { grid-template-columns: 1fr; min-height: auto; }
  .hero-left { padding: 120px 28px 60px; }
  .hero-right { display: none; }
  .hero-stats { gap: 28px; }
  .section-formules, .section-menu, .section-infos, footer { padding: 80px 24px; }
  .formules-grid { grid-template-columns: 1fr; }
  .section-header { flex-direction: column; gap: 24px; align-items: flex-start; }
